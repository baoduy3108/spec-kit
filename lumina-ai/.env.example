# ✦ LUMINA AI — sao chép file này thành .env rồi điền giá trị thật
# (KHÔNG commit file .env lên git)

# ── BẮT BUỘC ────────────────────────────────────────────────────
# API key Claude — lấy tại https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth Client ID — tạo tại https://console.cloud.google.com/apis/credentials
# (loại "Web application", thêm domain web của bạn vào Authorized JavaScript origins)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Chuỗi bí mật ký phiên đăng nhập — tự sinh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── TÙY CHỌN ────────────────────────────────────────────────────
# Bật Claude Fable 5 cho tác vụ khó nhất (giá cao hơn, cần org đủ điều kiện)
ENABLE_FABLE=false

# Engine dự phòng — chỉ điền nếu muốn "ổn định như ChatGPT" khi Claude sự cố
GEMINI_API_KEY=
OPENAI_API_KEY=

# Tìm kiếm cho engine dự phòng OpenAI (Claude tự có web search, không cần)
TAVILY_API_KEY=

# Giới hạn lượt mỗi người dùng / phút — áp dụng cho gói MIỄN PHÍ (bảo vệ chi phí API)
RATE_LIMIT_RPM=10
RATE_LIMIT_BURST=15

# CHỈ khi chạy thử trên máy (bỏ qua đăng nhập Google) — ĐỪNG bật trên web công khai
DEV_MODE=false

# ── GÓI TRẢ PHÍ (Tháng / Năm) ────────────────────────────────────
# Email của bạn (và người quản trị khác nếu có), cách nhau bởi dấu phẩy.
# Các email này mới vào được trang quản trị để tạo mã kích hoạt.
ADMIN_EMAILS=your-email@gmail.com

# Giá gói (VNĐ) — sửa theo ý bạn
PRICE_MONTHLY_VND=79000
PRICE_YEARLY_VND=690000

# Giới hạn của gói MIỄN PHÍ (số tin nhắn mỗi ngày).
# Mặc định RẤT thấp có chủ đích — dùng khi ngân sách API ban đầu chỉ vài chục đô:
# khách chỉ chat thử được 1-2 lượt/ngày rồi phải mua gói mới dùng tiếp, tránh
# bị "cháy" tiền API vì người lạ dùng chùa. Tăng dần con số này khi có thêm ngân sách.
FREE_DAILY_CAP=2

# Giới hạn của gói TRẢ PHÍ (số tin nhắn mỗi ngày + lượt/phút) — cao hơn hẳn miễn phí
PAID_DAILY_CAP=500
PAID_RPM=30
PAID_BURST=50

# Thông tin chuyển khoản thủ công hiển thị khi người dùng bấm "Nâng cấp"
# (chưa tích hợp cổng thanh toán tự động — bạn xác nhận tiền vào rồi tạo mã
# kích hoạt gửi cho người dùng qua mục quản trị trên web)
PAYMENT_BANK_NAME=Vietcombank
PAYMENT_BANK_ACCOUNT=0123456789
PAYMENT_BANK_OWNER=NGUYEN VAN A
PAYMENT_MOMO=0901234567
PAYMENT_NOTE=Ghi noi dung chuyen khoan: email dang nhap cua ban
