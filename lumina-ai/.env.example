# ✦ LUMINA AI — sao chép file này thành .env rồi điền giá trị thật
# (KHÔNG commit file .env lên git)

# ── BỘ NÃO (cần ÍT NHẤT MỘT cái) ────────────────────────────────
# Cách hoạt động: Claude lo N lượt "cao cấp" đầu mỗi ngày (chất lượng cao nhất),
# hết thì LUMINA tự tụt xuống các bộ não MIỄN PHÍ bên dưới — tất cả giấu dưới tên
# "LUMINA", người dùng không biết đang chạy model nào.

# (Cao cấp, có tính phí) Claude — https://console.anthropic.com/settings/keys
# Không có cũng được: LUMINA sẽ chạy hoàn toàn bằng bộ não miễn phí bên dưới.
ANTHROPIC_API_KEY=

# (MIỄN PHÍ) Google Gemini — https://aistudio.google.com/apikey  ← khuyến nghị điền cái này
GEMINI_API_KEY=
# (MIỄN PHÍ, rất nhanh) Groq (chạy Llama) — https://console.groq.com/keys
# ⚠️ KHÔNG điền key thật vào file MẪU này (nó bị đưa lên GitHub công khai).
#    Điền key thật ở file .env trên máy chủ / Render dashboard.
GROQ_API_KEY=
# (MIỄN PHÍ, 1 key nhiều model) OpenRouter — https://openrouter.ai/keys
# Đổi OPENROUTER_MODEL nếu model free hết hạn mức (danh sách: openrouter.ai/models?max_price=0)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# (MIỄN PHÍ, có hạn mức, nhiều model GPT-4o/Llama/Mistral/DeepSeek/Phi) GitHub Models
#   — chỉ cần 1 GitHub token miễn phí: github.com/settings/tokens → Generate new token
#     (classic) → KHÔNG cần tick scope nào (public models không đòi scope) → copy vào đây.
#   Đổi model tùy ý: openai/gpt-4o-mini · meta/Llama-3.3-70B-Instruct · deepseek/DeepSeek-V3 ...
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
# (Cực rẻ) DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=
# (MIỄN PHÍ, chạy trên máy bạn) Ollama — cài tại https://ollama.com rồi điền URL
# Lưu ý: Render free KHÔNG chạy được Ollama; chỉ dùng khi tự host máy chủ riêng.
OLLAMA_BASE_URL=
# (Tùy chọn) OpenAI/ChatGPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── BẮT BUỘC ────────────────────────────────────────────────────
# Google OAuth Client ID — tạo tại https://console.cloud.google.com/apis/credentials
# (loại "Web application", thêm domain web của bạn vào Authorized JavaScript origins)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Chuỗi bí mật ký phiên đăng nhập — tự sinh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── TÙY CHỌN ────────────────────────────────────────────────────
# Bật chế độ 🌌 Đỉnh cao (Claude Fable 5 cho tác vụ khó nhất; giá cao hơn, cần org đủ điều kiện)
ENABLE_FABLE=false

# Tìm kiếm web cho các engine không có sẵn (Claude/Gemini tự có, không cần)
TAVILY_API_KEY=

# Giới hạn lượt mỗi người dùng / phút — áp dụng cho gói MIỄN PHÍ (bảo vệ chi phí API)
RATE_LIMIT_RPM=10
RATE_LIMIT_BURST=15

# CHỈ khi chạy thử trên máy (bỏ qua đăng nhập Google) — ĐỪNG bật trên web công khai
DEV_MODE=false

# ── GÓI TRẢ PHÍ (Tháng / Năm) ────────────────────────────────────
# Email của bạn (và người quản trị khác nếu có), cách nhau bởi dấu phẩy.
# Các email này mới vào được mục "🛠 Đơn hàng" để xem/xử lý đơn.
ADMIN_EMAILS=your-email@gmail.com

# Giá gói — sửa theo ý bạn (VNĐ cho khách VN, USD cho khách quốc tế)
PRICE_MONTHLY_VND=500000
PRICE_MONTHLY_USD=20
PRICE_YEARLY_VND=5000000
PRICE_YEARLY_USD=200

# Gói MIỄN PHÍ: số lượt "cao cấp" (Claude) mỗi ngày rất thấp có chủ đích — bảo vệ
# ngân sách API nhỏ. Hết lượt cao cấp thì tự dùng bộ não free (không tốn tiền),
# tối đa FREE_TOTAL_CAP tin nhắn/ngày. Tăng dần khi có thêm ngân sách.
FREE_PREMIUM_CAP=2
FREE_TOTAL_CAP=30

# Gói TRẢ PHÍ: nhiều lượt cao cấp hơn + tổng lượt/ngày cao hơn + lượt/phút cao hơn
PAID_PREMIUM_CAP=200
PAID_TOTAL_CAP=1000
PAID_RPM=30
PAID_BURST=50

# ── THANH TOÁN TỰ ĐỘNG ───────────────────────────────────────────
# (A) SePay — khách VN quét QR chuyển khoản, tiền về THẲNG tài khoản bạn.
#     B1: đăng ký free tại https://sepay.vn → nối tài khoản ngân hàng.
#     B2: đặt Webhook URL trong SePay = https://<web-cua-ban>/api/webhook/sepay
#     B3: lấy API key của SePay điền vào đây (dùng xác thực webhook).
SEPAY_API_KEY=
# Thông tin nhận tiền (dùng tạo mã QR động cho khách):
PAYMENT_BANK_BIN=970436          # mã BIN ngân hàng — tra tại vietqr.io (970436 = Vietcombank)
PAYMENT_BANK_ACCOUNT=0123456789  # số tài khoản nhận tiền
PAYMENT_BANK_OWNER=NGUYEN VAN A  # tên chủ TK, IN HOA KHÔNG DẤU
PAYMENT_BANK_NAME=Vietcombank    # tên ngân hàng (hiển thị cho khách)

# (B) PayPal — khách quốc tế trả thẻ/PayPal, tiền về THẲNG ví PayPal của bạn.
#     Tạo REST App tại https://developer.paypal.com/dashboard → lấy Client ID + Secret.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=live                 # "live" khi chạy thật, "sandbox" khi test

# Đơn chờ thanh toán quá số phút này coi như hết hạn
ORDER_TTL_MINUTES=30
