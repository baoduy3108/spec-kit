# ✦ LUMINA AI — sao chép file này thành .env rồi điền giá trị thật
# (KHÔNG commit file .env lên git)

# ── BẮT BUỘC ────────────────────────────────────────────────────
# API key Claude — lấy tại https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth Client ID — tạo tại https://console.cloud.google.com/apis/credentials
# (loại "Web application", thêm domain web của bạn vào Authorized JavaScript origins)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Chuỗi bí mật ký phiên đăng nhập — tự sinh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── TÙY CHỌN ────────────────────────────────────────────────────
# Bật Claude Fable 5 cho tác vụ khó nhất (giá cao hơn, cần org đủ điều kiện)
ENABLE_FABLE=false

# Engine dự phòng — chỉ điền nếu muốn "ổn định như ChatGPT" khi Claude sự cố
GEMINI_API_KEY=
OPENAI_API_KEY=

# Tìm kiếm cho engine dự phòng OpenAI (Claude tự có web search, không cần)
TAVILY_API_KEY=

# Giới hạn lượt mỗi người dùng / phút (bảo vệ chi phí API)
RATE_LIMIT_RPM=10
RATE_LIMIT_BURST=15

# CHỈ khi chạy thử trên máy (bỏ qua đăng nhập Google) — ĐỪNG bật trên web công khai
DEV_MODE=false
